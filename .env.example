APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=7777

DB_FILE=data/app.db
WORKSPACE_ROOT=data/workspaces
SEED_DOCS_DIR=docs/seed

JWT_SECRET=dev-secret-change-me-local-2026-x
JWT_ISSUER=agno-enterprise-local
JWT_AUDIENCE=agno-enterprise-users

DEFAULT_TENANT_ID=demo
DEFAULT_PROJECT_ID=alpha

LITELLM_PROXY_BASE_URL=http://127.0.0.1:4000
LITELLM_MASTER_KEY=local-litellm-master-key
LITELLM_PROXY_CONFIG=configs/litellm_proxy.yaml
MODEL_ROUTER_CONFIG=configs/model_router.yaml
AGENT_DISCOVERY_CONFIG=configs/agent_discovery.yaml
LITELLM_REQUEST_TIMEOUT_SECONDS=45
LITELLM_HEALTH_TTL_SECONDS=15
LITELLM_PROBE_PROMPT=Reply with OK.

OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_CODER_MODEL=openai/gpt-5.3-codex

MINIMAX_API_BASE=
MINIMAX_API_KEY=
MINIMAX_MODEL_ID=

ZAI_API_BASE=
ZAI_API_KEY=
ZAI_MODEL_ID=

CODER_PREMIUM_ADAPTER_BASE_URL=http://127.0.0.1:4101/v1
CODER_PREMIUM_ADAPTER_KEY=local-coder-premium-key
CODER_PREMIUM_MODEL=gpt-5.4
CODER_PREMIUM_REASONING_EFFORT=medium
CODER_PREMIUM_SUMMARY_MODE=concise
CODER_PREMIUM_PERSONALITY=friendly

EXTERNAL_AGENT_CATALOG_FILE=data/external_agents/catalog.json
EXTERNAL_AGENT_BASE_URL=http://127.0.0.1:7777
SKILLS_ROOT=skills
CODEX_SAFE_CWD_ROOT=data/codex_sandbox
EXEC_SANDBOX_ENABLED=true
EXEC_SANDBOX_MODE=docker
EXEC_JOBS_ROOT=data/exec_jobs
EXEC_DEFAULT_TIMEOUT_SECONDS=30
EXEC_MAX_TIMEOUT_SECONDS=120
EXEC_DEFAULT_MEMORY_MB=512
EXEC_MAX_MEMORY_MB=1024
EXEC_DEFAULT_CPU_LIMIT=1.0
EXEC_ALLOW_NETWORK=false
EXEC_ALLOW_WORKSPACE_WRITEBACK=false
EXEC_MAX_STDOUT_CHARS=20000
EXEC_MAX_STDERR_CHARS=20000
EXEC_CONTAINER_IMAGE=python:3.11-slim
EXTERNAL_PREFETCH_ENABLED=true
EXTERNAL_PREFETCH_MODE=prefetch
MCP_ALLOW_WRITE=true
WORKSPACE_GUARD_ENABLED=false
EXECUTION_GUARD_ENABLED=false

ALLOW_MOCK_FALLBACK=true
TELEMETRY_ENABLED=false
AGNO_TRACING_ENABLED=false
CODEX_BRIDGE_ENABLED=true
CODEX_AUTH_FILE=~/.codex/auth.json
CODEX_BRIDGE_DEFAULT_ROLE=manager
CODEX_BRIDGE_PROJECT_IDS=alpha
CODEX_BRIDGE_DEFAULT_PROJECT_ID=alpha
